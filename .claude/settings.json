{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/session-env-setup.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/sessionstart-envdrift.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/pre-commit-checks.sh",
            "timeout": 120000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/format-on-edit.sh",
            "timeout": 30000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/pr-stale-check.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/tmux-on-stop.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/tmux-on-notification.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/steverhoton/.claude/hooks/tmux-on-session-end.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/steverhoton/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "aws-core@agent-toolkit-for-aws": true,
    "aws-agents@agent-toolkit-for-aws": true,
    "aws-data-analytics@agent-toolkit-for-aws": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "agent-toolkit-for-aws": {
      "source": {
        "source": "github",
        "repo": "aws/agent-toolkit-for-aws"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "verbose": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754086649066
  }
}
